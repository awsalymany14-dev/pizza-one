<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>منيو مطعم بيتزا ون - فرع السر</title>
    <style>
        :root {
            --primary-color: #ce1212;
            --secondary-color: #f4b41a;
            --dark-color: #141414;
            --light-color: #f7f7f7;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: var(--light-color); color: var(--dark-color); padding-bottom: 100px; }
        header { background-color: var(--primary-color); color: white; text-align: center; padding: 20px; border-bottom: 4px solid var(--secondary-color); }
        header h1 { font-size: 24px; margin-bottom: 5px; }
        .container { max-width: 600px; margin: 20px auto; padding: 0 15px; }
        .section-title { background: var(--dark-color); color: var(--secondary-color); padding: 8px 15px; margin: 20px 0 10px 0; border-radius: 5px; font-size: 18px; }
        .product-card { background: white; padding: 15px; margin-bottom: 10px; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        .product-info h3 { font-size: 16px; margin-bottom: 5px; }
        .product-price { color: var(--primary-color); font-weight: bold; font-size: 14px; }
        .btn-add { background-color: var(--secondary-color); border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-weight: bold; }
        .bank-info { background: #e8f4fd; border: 1px solid #bce0fd; padding: 15px; border-radius: 8px; margin-top: 20px; font-size: 14px; line-height: 1.6; }
        .bank-info h4 { color: #004085; margin-bottom: 8px; }
        .footer-cart { position: fixed; bottom: 0; left: 0; right: 0; background: white; padding: 15px; box-shadow: 0 -3px 10px rgba(0,0,0,0.1); display: flex; justify-content: space-between; align-items: center; max-width: 600px; margin: 0 auto; z-index: 1000; }
        .btn-order { background-color: #25D366; color: white; border: none; padding: 10px 20px; border-radius: 5px; font-weight: bold; cursor: pointer; font-size: 16px; text-decoration: none; }
    </style>
</head>
<body>

<header>
    <h1>بيتزا ون (فرع السر)</h1>
    <p>تلفون: 0534169477</p>
</header>

<div class="container">
    <!-- قسم البيتزا -->
    <div class="section-title">🍕 البيتزا</div>
    <div class="product-card">
        <div class="product-info">
            <h3>بيتزا خضار (وسط)</h3>
            <div class="product-price">14 رس</div>
        </div>
        <button class="btn-add" onclick="addToCart('بيتزا خضار (وسط)', 14)">إضافة</button>
    </div>
    <div class="product-card">
        <div class="product-info">
            <h3>بيتزا خضار (كبير)</h3>
            <div class="product-price">18 رس</div>
        </div>
        <button class="btn-add" onclick="addToCart('بيتزا خضار (كبير)', 18)">إضافة</button>
    </div>
    <div class="product-card">
        <div class="product-info">
            <h3>بيتزا بروني (وسط)</h3>
            <div class="product-price">13 رس</div>
        </div>
        <button class="btn-add" onclick="addToCart('بيتزا بروني (وسط)', 13)">إضافة</button>
    </div>

    <!-- قسم الشاورما والمشويات -->
    <div class="section-title">🌯 الشاورما والمشويات</div>
    <div class="product-card">
        <div class="product-info">
            <h3>سندوتش شاورما صغير</h3>
            <div class="product-price">6 رس</div>
        </div>
        <button class="btn-add" onclick="addToCart('سندوتش شاورما صغير', 6)">إضافة</button>
    </div>
    <div class="product-card">
        <div class="product-info">
            <h3>كباب دجاج (سيخ)</h3>
            <div class="product-price">6 Legal رس</div>
        </div>
        <button class="btn-add" onclick="addToCart('كباب دجاج', 6)">إضافة</button>
    </div>

    <!-- قسم العصائر -->
    <div class="section-title">🍹 العصائر الطازجة</div>
    <div class="product-card">
        <div class="product-info">
            <h3>عوار قلب (كاسة وسط)</h3>
            <div class="product-price">7 رس</div>
        </div>
        <button class="btn-add" onclick="addToCart('عوار قلب (وسط)', 7)">إضافة</button>
    </div>
    <div class="product-card">
        <div class="product-info">
            <h3>كوكتيل ملكي (جالون صغير)</h3>
            <div class="product-price">15 رس</div>
        </div>
        <button class="btn-add" onclick="addToCart('كوكتيل ملكي (جالون ص)', 15)">إضافة</button>
    </div>

    <!-- تفاصيل الحساب البنكي -->
    <div class="bank-info">
        <h4>🏦 تفاصيل الحساب البنكي للتحويل:</h4>
        <p><strong>المصرف:</strong> مصرف الإنماء</p>
        <p><strong>اسم الحساب:</strong> Mtaam Dalal Maywd Musfir Alharthi L</p>
        <p><strong>رقم الحساب:</strong> 68205190184000</p>
        <p><strong>الآيبان:</strong> SA3005000068205190184000</p>
        <p style="color: red; margin-top: 5px; font-weight: bold;">* يرجى إرفاق صورة التحويل عند إرسال الطلب عبر الواتساب.</p>
    </div>
</div>

<!-- السلة السفلية الثابتة -->
<div class="footer-cart">
    <div>
        <div><strong>السلة:</strong> <span id="cart-count">0</span> أصناف</div>
        <div><strong>المجموع:</strong> <span id="cart-total">0</span> رس</div>
    </div>
    <button class="btn-order" onclick="sendWhatsAppOrder()">إرسال الطلب عبر الواتساب</button>
</div>

<script>
    let cart = [];
    let total = 0;

    function addToCart(name, price) {
        cart.push({name: name, price: price});
        total += price;
        document.getElementById('cart-count').innerText = cart.length;
        document.getElementById('cart-total').innerText = total;
        alert('تم إضافة ' + name + ' إلى السلة');
    }

    function sendWhatsAppOrder() {
        if(cart.length === 0) {
            alert('السلة فارغة! يرجى إضافة أصناف أولاً.');
            return;
        }

        let phoneNumber = "966534169477";
        let text = "*طلب جديد من منيو بيتزا ون (السر)*\n\n";
        
        cart.forEach((item, index) => {
            text += `${index + 1}. ${item.name} - ${item.price} رس\n`;
        });

        text += `\n*المجموع الإجمالي:* ${total} رس\n`;
        text += `\n--- _تفاصيل الحساب البنكي المحول إليه_ ---\n`;
        text += `*المصرف:* الإنماء\n`;
        text += `*الحساب:* 68205190184000\n`;
        text += `_أنا بصدد إرسال صورة إيصال التحويل الآن._`;

        let encodedText = encodeURIComponent(text);
        let url = `https://wa.me/${phoneNumber}?text=${encodedText}`;
        
        window.open(url, '_blank');
    }
</script>

</body>
</html>
